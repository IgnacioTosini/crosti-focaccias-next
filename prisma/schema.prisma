generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DATABASE_URL")
}

enum FocacciaSize {
    MEDIANA
    GRANDE
}

enum PedidoStatus {
    PENDIENTE
    CONFIRMADO
    EN_PREPARACION
    LISTO
    ENTREGADO
    CANCELADO
}

enum PromocionType {
    FOCACCIAS
    PREPIZZAS
    COMBOS
}

enum PromocionItemType {
    FOCACCIA
    PREPIZZA
    EXTRA
}

model Focaccia {
    id              Int              @id @default(autoincrement())
    name            String
    description     String
    mediumPrice     Float
    largePrice      Float
    isVeggie        Boolean          @default(false)
    imageUrl        String
    imagePublicId   String
    featured        Boolean          @default(false)
    isAvailable     Boolean          @default(true)
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    pedidoFocaccias PedidoFocaccia[]
}

model Pedido {
    id              Int              @id @default(autoincrement())
    orderNumber     String           @unique @default(cuid())
    clientPhone     String
    status          PedidoStatus     @default(PENDIENTE)
    quantity        Int
    subtotal        Float
    discountTotal   Float            @default(0)
    totalPrice      Float
    notes           String?
    orderDate       DateTime         @default(now())
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    deliveredAt     DateTime?
    pedidoFocaccias PedidoFocaccia[]

    @@index([clientPhone, orderDate])
    @@index([status, orderDate])
}

model PedidoFocaccia {
    id           Int          @id @default(autoincrement())
    pedidoId     Int
    focacciaId   Int?
    size         FocacciaSize
    cantidad     Int
    unitPrice    Float
    lineSubtotal Float
    lineDiscount Float        @default(0)
    lineTotal    Float
    pedido       Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
    focaccia     Focaccia?    @relation(fields: [focacciaId], references: [id], onDelete: SetNull)

    @@unique([pedidoId, focacciaId, size])
    @@index([focacciaId])
}

model Promocion {
    id          Int      @id @default(autoincrement())
    people      Int
    title       String
    description String
    price       Float
    type        PromocionType @default(COMBOS)
    items       PromocionItem[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model PromocionItem {
    id          Int               @id @default(autoincrement())
    promocionId Int
    itemType    PromocionItemType
    label       String?
    quantity    Int               @default(1)
    size        FocacciaSize?
    order       Int               @default(0)
    promocion   Promocion         @relation(fields: [promocionId], references: [id], onDelete: Cascade)

    @@index([promocionId])
}
